<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_pl_accounts" model="ir.actions.report">
        <field name="name">Comptes produits et charges</field>
        <field name="model">pl.accounts.report.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">budget_studio_pl_accounts.report_pl_accounts_document</field>
        <field name="report_file">budget_studio_pl_accounts.report_pl_accounts_document</field>
        <field name="print_report_name">'Comptes_produits_charges - %s' % (object.company_id.name)</field>
    </record>

    <template id="report_pl_accounts_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="wiz">
                <t t-set="company" t-value="wiz.company_id"/>
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2 class="mt-3">Comptes produits et charges</h2>
                        <p class="text-muted">
                            Liste des comptes du compte de résultat (produits et charges) — <span t-esc="company.name"/>
                        </p>

                        <h4 class="mt-4 mb-2">Produits</h4>
                        <t t-if="rows_income">
                            <table class="table table-sm table-bordered o_main_table">
                                <thead>
                                    <tr>
                                        <th>Code</th>
                                        <th>Libellé</th>
                                        <th>Type de compte</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="rows_income" t-as="line">
                                        <tr>
                                            <td><span t-esc="line['code']"/></td>
                                            <td><span t-esc="line['name']"/></td>
                                            <td><span t-esc="line['type_label']"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>
                        <t t-if="not rows_income">
                            <p><em>Aucun compte de produits.</em></p>
                        </t>

                        <h4 class="mt-4 mb-2">Charges</h4>
                        <t t-if="rows_expense">
                            <table class="table table-sm table-bordered o_main_table">
                                <thead>
                                    <tr>
                                        <th>Code</th>
                                        <th>Libellé</th>
                                        <th>Type de compte</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="rows_expense" t-as="line">
                                        <tr>
                                            <td><span t-esc="line['code']"/></td>
                                            <td><span t-esc="line['name']"/></td>
                                            <td><span t-esc="line['type_label']"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>
                        <t t-if="not rows_expense">
                            <p><em>Aucun compte de charges.</em></p>
                        </t>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
