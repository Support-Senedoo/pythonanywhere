{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Toolbox Flask (local)",
      "type": "shell",
      "command": "${workspaceFolder}/run_toolbox_local.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      },
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },
    {
      "label": "PythonAnywhere deploy (bash)",
      "type": "shell",
      "command": "bash",
      "args": ["${workspaceFolder}/deploy_to_pa.sh", "-SkipGitPush"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      },
      "group": "build"
    }
  ]
}
