# À fusionner dans %USERPROFILE%\.ssh\config (créer le dossier .ssh et le fichier si besoin).
# Ensuite : ssh pa   ou   .\deploy_pa.ps1 -UserHost pa   ou   DEPLOY_PA_SSH=senedoo@pa bash deploy_to_pa.sh -SkipGitPush
# (deploy_to_pa.sh : voir odoo-pythonanywhere/deploy_to_pa.sh ; alias SSH non lu par le script sans DEPLOY_PA_SSH)
#
# EU : HostName ssh.eu.pythonanywhere.com

Host pa
    HostName ssh.pythonanywhere.com
    User senedoo
    # Préférer la clé sans phrase pour l’automatisation (voir setup_pa_automation_key.ps1) :
    IdentityFile ~/.ssh/id_ed25519_pa_cursor
    IdentitiesOnly yes
    StrictHostKeyChecking accept-new

# Host pa-main
#     HostName ssh.pythonanywhere.com
#     User senedoo
#     IdentityFile ~/.ssh/id_ed25519
