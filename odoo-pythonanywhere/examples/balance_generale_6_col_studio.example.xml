<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
      Balance générale 6 colonnes (visée OHADA) — gabarit Studio / module custom, Odoo v19+.

      Odoo 19 : sur une ligne avec groupby, le moteur « aggregation » peut être refusé (schéma
      communautaire strict) ; le script create_balance_6cols_via_api.py tente d’abord
      « aggregation » si le serveur l’autorise, sinon « domain ». Ce gabarit XML reste en
      « domain » pour compatibilité Studio / import sans sonde RPC.

      Libellés d’expressions / expression_label des colonnes : préfixe ohada6_ pour éviter les
      collisions avec debit / credit / debit_initial traités à part par le moteur standard.

      Option rapport : « Inclure le solde initial » activée si besoin pour les colonnes d’ouverture.

      Import Studio : en cas d’erreur, importer en deux temps (colonnes puis ligne + rapport).
    -->

    <record id="report_balance_6_col_example" model="account.report">
        <field name="name">Balance générale 6 colonnes (exemple)</field>
    </record>

    <record id="col_debit_initial_example" model="account.report.column">
        <field name="report_id" ref="report_balance_6_col_example"/>
        <field name="sequence" eval="10"/>
        <field name="name">Débit initial</field>
        <field name="expression_label">ohada6_open_deb</field>
        <field name="figure_type">monetary</field>
    </record>

    <record id="col_credit_initial_example" model="account.report.column">
        <field name="report_id" ref="report_balance_6_col_example"/>
        <field name="sequence" eval="20"/>
        <field name="name">Crédit initial</field>
        <field name="expression_label">ohada6_open_cre</field>
        <field name="figure_type">monetary</field>
    </record>

    <record id="col_debit_example" model="account.report.column">
        <field name="report_id" ref="report_balance_6_col_example"/>
        <field name="sequence" eval="30"/>
        <field name="name">Débit</field>
        <field name="expression_label">ohada6_mov_deb</field>
        <field name="figure_type">monetary</field>
    </record>

    <record id="col_credit_example" model="account.report.column">
        <field name="report_id" ref="report_balance_6_col_example"/>
        <field name="sequence" eval="40"/>
        <field name="name">Crédit</field>
        <field name="expression_label">ohada6_mov_cre</field>
        <field name="figure_type">monetary</field>
    </record>

    <record id="col_debit_final_example" model="account.report.column">
        <field name="report_id" ref="report_balance_6_col_example"/>
        <field name="sequence" eval="50"/>
        <field name="name">Débit final</field>
        <field name="expression_label">ohada6_close_deb</field>
        <field name="figure_type">monetary</field>
    </record>

    <record id="col_credit_final_example" model="account.report.column">
        <field name="report_id" ref="report_balance_6_col_example"/>
        <field name="sequence" eval="60"/>
        <field name="name">Crédit final</field>
        <field name="expression_label">ohada6_close_cre</field>
        <field name="figure_type">monetary</field>
    </record>

    <record id="line_balance_accounts_example" model="account.report.line">
        <field name="report_id" ref="report_balance_6_col_example"/>
        <field name="name">Balance</field>
        <field name="code">bal6_example</field>
        <field name="groupby">account_id</field>
        <field name="expression_ids" eval="[
            (0, 0, {
                'label': 'ohada6_open_deb',
                'engine': 'domain',
                'formula': '[]',
                'subformula': 'sum_if_pos',
                'date_scope': 'to_beginning_of_period',
            }),
            (0, 0, {
                'label': 'ohada6_open_cre',
                'engine': 'domain',
                'formula': '[]',
                'subformula': '-sum_if_neg',
                'date_scope': 'to_beginning_of_period',
            }),
            (0, 0, {
                'label': 'ohada6_mov_deb',
                'engine': 'domain',
                'formula': &quot;[('debit', '&gt;', 0)]&quot;,
                'subformula': 'sum',
                'date_scope': 'strict_range',
            }),
            (0, 0, {
                'label': 'ohada6_mov_cre',
                'engine': 'domain',
                'formula': &quot;[('credit', '&gt;', 0)]&quot;,
                'subformula': '-sum',
                'date_scope': 'strict_range',
            }),
            (0, 0, {
                'label': 'ohada6_close_deb',
                'engine': 'domain',
                'formula': '[]',
                'subformula': 'sum_if_pos',
                'date_scope': 'from_beginning',
            }),
            (0, 0, {
                'label': 'ohada6_close_cre',
                'engine': 'domain',
                'formula': '[]',
                'subformula': '-sum_if_neg',
                'date_scope': 'from_beginning',
            }),
        ]"/>
    </record>
</odoo>
