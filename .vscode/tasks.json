{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Publier sur PythonAnywhere",
      "type": "shell",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/odoo-pythonanywhere/deploy_pa.ps1"
      ],
      "options": {
        "cwd": "${workspaceFolder}/odoo-pythonanywhere"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "group": "build"
    },
    {
      "label": "Toolbox Flask (local)",
      "type": "shell",
      "command": "bash",
      "args": ["${workspaceFolder}/odoo-pythonanywhere/run_toolbox_local.sh"],
      "options": {
        "cwd": "${workspaceFolder}/odoo-pythonanywhere"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      },
      "group": "build"
    },
    {
      "label": "PythonAnywhere deploy (bash)",
      "type": "shell",
      "command": "bash",
      "args": [
        "${workspaceFolder}/odoo-pythonanywhere/deploy_to_pa.sh",
        "-SkipGitPush"
      ],
      "options": {
        "cwd": "${workspaceFolder}/odoo-pythonanywhere"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      },
      "group": "build"
    }
  ]
}
